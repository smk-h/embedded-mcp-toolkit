{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "embedded-board": {
      "type": "local",
      "command": ["./out/index.js"],
      "enabled": true,
      "environment": {
        "BOARD_HOST": "192.168.16.103",
        "BOARD_PORT": "22",
        "BOARD_USERNAME": "root",
        "BOARD_PASSWORD": "root"
      }
    },
    "board-beta": {
      "type": "local",
      "command": ["./out/index.js"],
      "enabled": true,
      "environment": {
        "BOARD_HOST": "192.168.16.105",
        "BOARD_PORT": "22",
        "BOARD_USERNAME": "root",
        "BOARD_PASSWORD": "root",
        "BOARD_HOST_KEY_ALGORITHMS": "ssh-rsa"
      }
    },
    "board-alpha": {
      "type": "local",
      "command": ["./out/index.js"],
      "enabled": true,
      "environment": {
        "SERIAL_PORT": "COM3",
        "SERIAL_BAUDRATE": "115200",
        "SERIAL_DATABITS": "8",
        "SERIAL_STOPBITS": "1",
        "SERIAL_PARITY": "none"
      }
    }
  }
}
