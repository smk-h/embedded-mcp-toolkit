{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "embedded-board": {
      "type": "local",
      "command": ["node", "./bin/embedded-mcp-toolkit-cli.js"],
      "enabled": true,
      "environment": {
        "DEVICE": "board-b",
        "BOARD_CONFIG_PATH": "./configs/config.yaml",
        "LOG_SAVE": "1",
        "LOG_DIR": "./log"
      }
    }
  }
}
