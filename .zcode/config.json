{
  "$schema": "https://json.schemastore.org/zcode-config.json",
  "mcp": {
    "servers": {
      "embedded-board": {
        "type": "stdio",
        "command": "node",
        "args": ["./bin/embedded-mcp-toolkit-cli.js"],
        "env": {
          "DEVICE": "board-b",
          "BOARD_CONFIG_PATH": "./.embedded/configs/config.yaml",
          "LOG_SAVE": "1",
          "LOG_DIR": "./.embedded/log",
          "SAVE2FILE_PATH": "./.embedded/log"
        }
      },
      "file_utils_remote": {
        "type": "stdio",
        "command": "ssh",
        "args": [
          "-i", "~/.ssh/id_file_utils_remote",
          "-o", "ServerAliveInterval=60",
          "sumu@192.168.164.128",
          "PATH=$HOME/.npm-global/bin:$PATH file-utils-mcp-toolkit"
        ],
        "enabled": true,
        "timeout": 600000
      }
    }
  }
}
