{
  "name": "@smai-kit/embedded-mcp-toolkit",
  "version": "0.1.3",
  "description": "MCP Server for remote management of embedded Linux boards via SSH",
  "type": "module",
  "main": "out/index.js",
  "bin": {
    "embedded-mcp-toolkit": "./bin/embedded-mcp-toolkit-cli.js"
  },
  "scripts": {
    "build": "tsc",
    "clean": "rimraf out",
    "clean-log": "rimraf --glob ./.embedded/log/*.log",
    "dev": "tsc --watch",
    "start": "node out/index.js",
    "inspector": "npm run inspector:win",
    "inspector:win": "powershell -ExecutionPolicy Bypass -File scripts/run-inspector.ps1",
    "psh-demo-ssh": "node ./bin/embedded-mcp-toolkit-cli.js psh-demo-ssh",
    "psh-demo-serial": "node ./bin/embedded-mcp-toolkit-cli.js psh-demo-serial",
    "format:check": "prettier ./src --check",
    "format:fix": "prettier ./src --write",
    "eslint:fix": "eslint --fix -c eslint.config.ts src",
    "pack:dry-run": "npm pack --dry-run",
    "pack:tgz": "npm pack",
    "pack:list": "tar -tzf smai-kit-embedded-mcp-toolkit-%npm_package_version%.tgz",
    "pack:project": "node scripts/pack-project.cjs",
    "win:node-list": "tasklist | findstr node.exe",
    "win:node-kill": "taskkill /f /im node.exe",
    "win:open-home": "start %USERPROFILE%",
    "win:open-devmgr": "devmgmt.msc",
    "win:open-netadapter": "ncpa.cpl",
    "win:open-node-global": "for /f \"delims=\" %d in ('npm root -g') do @start \"\" \"%d\""
  },
  "dependencies": {
    "@cfworker/json-schema": "^4.1.1",
    "@modelcontextprotocol/server": "^2.0.0-alpha.2",
    "commander": "^14.0.3",
    "js-yaml": "^4.1.1",
    "serialport": "^13.0.0",
    "ssh2": "^1.16.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@modelcontextprotocol/inspector": "^0.21.2",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.0.0",
    "@types/ssh2": "^1.15.0",
    "adm-zip": "^0.5.17",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.6.0",
    "jiti": "^2.7.0",
    "prettier": "^3.8.3",
    "rimraf": "^6.1.3",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.60.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
