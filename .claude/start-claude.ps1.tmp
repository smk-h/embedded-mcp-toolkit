# Claude Code 启动脚本
# 设置环境变量并启动 Claude Code
# $MODEL_PROVIDER: "deepseek" | "glm"

$MODEL_PROVIDER = "deepseek"

switch ($MODEL_PROVIDER) {
    "deepseek" {
        # DeepSeek 配置
        $env:ANTHROPIC_AUTH_TOKEN = "<your-deepseek-api-key>"
        $env:ANTHROPIC_BASE_URL = "https://api.deepseek.com/anthropic"
        $env:ANTHROPIC_DEFAULT_HAIKU_MODEL = "deepseek-v4-flash"
        $env:ANTHROPIC_DEFAULT_SONNET_MODEL = "deepseek-v4-flash"
        $env:ANTHROPIC_DEFAULT_OPUS_MODEL = "deepseek-v4-flash"
        Write-Host "Using DeepSeek provider..."
    }
    "glm" {
        # GLM (智谱) 配置
        $env:ANTHROPIC_AUTH_TOKEN = "<your-glm-api-key>"
        $env:ANTHROPIC_BASE_URL = "https://open.bigmodel.cn/api/paas/v4/anthropic"
        $env:ANTHROPIC_DEFAULT_HAIKU_MODEL = "glm-4.5-air"
        $env:ANTHROPIC_DEFAULT_SONNET_MODEL = "glm-5.2[1m]"
        $env:ANTHROPIC_DEFAULT_OPUS_MODEL = "glm-5.2[1m]"
        $env:CLAUDE_CODE_AUTO_COMPACT_WINDOW = "1000000"
        Write-Host "Using GLM provider..."
    }
    default {
        Write-Host "Unknown MODEL_PROVIDER value: $MODEL_PROVIDER"
        exit 1
    }
}

$env:API_TIMEOUT_MS = "3000000"
$env:CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC = "1"

Write-Host "environment set success! Starting Claude Code..."
claude
