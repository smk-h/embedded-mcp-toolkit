{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "mcpServers": {
    "embedded-board": {
      "command": "node",
      "args": [
        "./bin/embedded-mcp-toolkit-cli.js"
      ],
      "env": {
        "DEVICE": "board-b",
        "BOARD_CONFIG_PATH": "./config/config.yaml",
        "LOG_SAVE": "1",
        "LOG_DIR": "./log"
      }
    }
  }
}
