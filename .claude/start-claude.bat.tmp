@echo off
REM Claude Code 启动脚本
REM 设置环境变量并启动 Claude Code

set ANTHROPIC_AUTH_TOKEN=sk-sp-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
set ANTHROPIC_BASE_URL=https://coding.dashscope.aliyuncs.com/apps/anthropic
set API_TIMEOUT_MS=3000000
set CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC=1
set ANTHROPIC_DEFAULT_HAIKU_MODEL=glm-5
set ANTHROPIC_DEFAULT_SONNET_MODEL=glm-5
set ANTHROPIC_DEFAULT_OPUS_MODEL=glm-5

echo "environment set success! Starting Claude Code..."
claude
